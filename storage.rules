rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /question_images/{fileName} {
      // Authenticated teachers and admins can upload images
      allow write: if request.auth != null
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['teacher', 'admin', 'super_admin'];
      // Any authenticated user can read images (students need to see them during tests)
      allow read: if request.auth != null;
    }

    match /ebooks/{fileName} {
      // Authenticated teachers and admins can upload e-books
      allow write: if request.auth != null
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['teacher', 'admin', 'super_admin'];
      // Any authenticated user can read/download e-books
      allow read: if request.auth != null;
    }

    // Deny all other storage access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
